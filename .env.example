# ---------------------------------------------------------------------------
# DATA project — dedicated SundayTurnering Supabase project (tournament tables,
# Realtime). Provisioned via scripts/provision.mjs. The DATA clients stay
# SESSION-LESS (service.ts service-role + client.ts anon Realtime) and never
# read/write the SSO session cookie.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL used to build the control-join URL + QR code on the board.
NEXT_PUBLIC_BASE_URL=https://turnering.sundaysuite.app

# ---------------------------------------------------------------------------
# AUTH — Sunday Account SSO issuer (a DIFFERENT Supabase project, the same one
# SundayInfo/SundayPlan use). Only the admin layer (/admin, /auth) touches this.
# The AUTH client owns the sb-* session cookie; anonymous play is unaffected.
# Leave all four UNSET to run turnering with no admin layer (anonymous-only).
# ---------------------------------------------------------------------------
# Issuer project URL + anon (publishable) key. Used by the auth client only.
NEXT_PUBLIC_SUNDAY_AUTH_URL=https://YOUR-SUNDAY-ACCOUNT-PROJECT.supabase.co
NEXT_PUBLIC_SUNDAY_AUTH_ANON_KEY=eyJ...
# Cross-subdomain SSO cookie domain (production only; leave UNSET for localhost
# so cookies keep working on http://localhost). Scopes the sb-* cookie so one
# login is shared across every *.sundaysuite.app app.
NEXT_PUBLIC_COOKIE_DOMAIN=.sundaysuite.app
# Allowlist of Sunday Account emails that may access /admin (comma- or
# whitespace-separated, case-insensitive). This is the ONLY authorisation rule.
TURNERING_ADMIN_EMAILS=you@example.com,other@example.com
